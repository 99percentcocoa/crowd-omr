DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omr_db
ALLOWED_USERS=+919876543210,+919876543211
BASE_IMAGE_URL=https://your-nginx-domain.com/images

EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_FROM_NUMBER=+911234567890

LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_CONSOLE=true
